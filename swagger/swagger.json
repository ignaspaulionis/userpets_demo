{
  "swagger": "2.0",
  "info": {
    "title": "Pets API",
    "version": "1.0.0"
  },
  "paths": {
    "/pets": {
      "get": {
        "summary": "Get a list of pets",
        "responses": {
          "200": {
            "description": "A list of pets",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Pet"
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new pet",
        "parameters": [
          {
            "in": "body",
            "name": "pet",
            "description": "Pet to be added",
            "schema": {
              "$ref": "#/definitions/Pet"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Pet added successfully"
          }
        }
      }
    },
    "/pets/{id}": {
      "put": {
        "summary": "Update a pet",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "description": "Pet ID"
          },
          {
            "in": "body",
            "name": "pet",
            "description": "Pet data to update",
            "schema": {
              "$ref": "#/definitions/Pet"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pet updated successfully"
          }
        }
      },
      "patch": {
        "summary": "Partially update a pet",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "description": "Pet ID"
          },
          {
            "in": "body",
            "name": "pet",
            "description": "Pet data to partially update",
            "schema": {
              "$ref": "#/definitions/Pet"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Pet partially updated successfully"
          }
        }
      },
      "delete": {
        "summary": "Delete a pet",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "description": "Pet ID"
          }
        ],
        "responses": {
          "204": {
            "description": "Pet deleted successfully"
          }
        }
      }
    },
    "/tags": {
      "get": {
        "summary": "Get a list of tags",
        "responses": {
          "200": {
            "description": "A list of tags",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Tag"
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new tag",
        "parameters": [
          {
            "in": "body",
            "name": "tag",
            "description": "Tag to be added",
            "schema": {
              "$ref": "#/definitions/TagInput"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Tag added successfully",
            "schema": {
              "$ref": "#/definitions/Tag"
            }
          }
        }
      }
    },
    "/tags/{id}": {
      "put": {
        "summary": "Update a tag",
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "type": "integer",
            "description": "Tag ID"
          },
          {
            "in": "body",
            "name": "tag",
            "description": "Tag data to update",
            "schema": {
              "$ref": "#/definitions/TagInput"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tag updated successfully",
            "schema": {
              "$ref": "#/definitions/Tag"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "Pet": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string",
          "example": "Bella"
        },
        "type": {
          "type": "string",
          "example": "Dog"
        },
        "age": {
          "type": "integer",
          "example": 3
        }
      }
    },
    "Tag": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string",
          "example": "Friendly"
        },
        "description": {
          "type": "string",
          "x-nullable": true,
          "example": "Used for calm and social pets"
        }
      }
    },
    "TagInput": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "example": "Friendly"
        },
        "description": {
          "type": "string",
          "x-nullable": true,
          "example": "Used for calm and social pets"
        }
      }
    }
  }
}
