{
    "swagger": "2.0",
    "info": {
      "title": "Pets API",
      "version": "1.0.0"
    },
    "paths": {
      "/pets": {
        "get": {
          "summary": "Get a list of pets",
          "responses": {
            "200": {
              "description": "A list of pets",
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/Pet"
                }
              }
            }
          }
        },
        "post": {
          "summary": "Add a new pet",
          "parameters": [
            {
              "in": "body",
              "name": "pet",
              "description": "Pet to be added",
              "schema": {
                "$ref": "#/definitions/Pet"
              }
            }
          ],
          "responses": {
            "201": {
              "description": "Pet added successfully"
            }
          }
        }
      },
      "/api/pets": {
        "get": {
          "summary": "Get a paginated list of pets",
          "parameters": [
            {
              "in": "query",
              "name": "page",
              "required": false,
              "type": "integer",
              "default": 1,
              "minimum": 1,
              "description": "Page number"
            },
            {
              "in": "query",
              "name": "limit",
              "required": false,
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100,
              "description": "Items per page (max 100)"
            }
          ],
          "responses": {
            "200": {
              "description": "Paginated pets response",
              "schema": {
                "$ref": "#/definitions/PaginatedPetsResponse"
              }
            },
            "400": {
              "description": "Invalid pagination query params",
              "schema": {
                "$ref": "#/definitions/Error"
              }
            }
          }
        }
      },
      "/pets/{id}": {
        "put": {
          "summary": "Update a pet",
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "required": true,
              "type": "integer",
              "description": "Pet ID"
            },
            {
              "in": "body",
              "name": "pet",
              "description": "Pet data to update",
              "schema": {
                "$ref": "#/definitions/Pet"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Pet updated successfully"
            }
          }
        },
        "patch": {
          "summary": "Partially update a pet",
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "required": true,
              "type": "integer",
              "description": "Pet ID"
            },
            {
              "in": "body",
              "name": "pet",
              "description": "Pet data to partially update",
              "schema": {
                "$ref": "#/definitions/Pet"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Pet partially updated successfully"
            }
          }
        },
        "delete": {
          "summary": "Delete a pet",
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "required": true,
              "type": "integer",
              "description": "Pet ID"
            }
          ],
          "responses": {
            "204": {
              "description": "Pet deleted successfully"
            }
          }
        }
      }
    },
    "definitions": {
      "Pet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "example": "Bella"
          },
          "type": {
            "type": "string",
            "example": "Dog"
          },
          "age": {
            "type": "integer",
            "example": 3
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": { "type": "integer", "example": 1 },
          "limit": { "type": "integer", "example": 10 },
          "total": { "type": "integer", "example": 23 },
          "totalPages": { "type": "integer", "example": 3 }
        }
      },
      "PaginatedPetsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/definitions/Pet" }
          },
          "pagination": { "$ref": "#/definitions/Pagination" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "page must be a positive integer"
          }
        }
      }
    }
  }
  