{
    "swagger": "2.0",
    "info": {
      "title": "Pets API",
      "version": "1.0.0"
    },
    "paths": {
      "/pets": {
        "get": {
          "summary": "Get a list of pets",
          "responses": {
            "200": {
              "description": "A list of pets with owner info",
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/PetWithOwner"
                }
              }
            }
          }
        },
        "post": {
          "summary": "Add a new pet",
          "parameters": [
            {
              "in": "body",
              "name": "pet",
              "description": "Pet to be added",
              "schema": {
                "$ref": "#/definitions/PetInput"
              }
            }
          ],
          "responses": {
            "201": {
              "description": "Pet added successfully",
              "schema": {
                "$ref": "#/definitions/PetWithOwner"
              }
            },
            "400": {
              "description": "Validation error"
            },
            "404": {
              "description": "User not found (when userId is provided)"
            }
          }
        }
      },
      "/pets/{id}": {
        "put": {
          "summary": "Update a pet",
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "required": true,
              "type": "integer",
              "description": "Pet ID"
            },
            {
              "in": "body",
              "name": "pet",
              "description": "Pet data to update",
              "schema": {
                "$ref": "#/definitions/PetInput"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Pet updated successfully"
            }
          }
        },
        "patch": {
          "summary": "Partially update a pet",
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "required": true,
              "type": "integer",
              "description": "Pet ID"
            },
            {
              "in": "body",
              "name": "pet",
              "description": "Pet data to partially update",
              "schema": {
                "$ref": "#/definitions/PetInput"
              }
            }
          ],
          "responses": {
            "200": {
              "description": "Pet partially updated successfully"
            }
          }
        },
        "delete": {
          "summary": "Delete a pet",
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "required": true,
              "type": "integer",
              "description": "Pet ID"
            }
          ],
          "responses": {
            "204": {
              "description": "Pet deleted successfully"
            }
          }
        }
      },
      "/users/{id}/pets": {
        "get": {
          "summary": "Get all pets for a user",
          "parameters": [
            {
              "in": "path",
              "name": "id",
              "required": true,
              "type": "integer",
              "description": "User ID"
            }
          ],
          "responses": {
            "200": {
              "description": "List of pets belonging to the user",
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/definitions/PetWithOwner"
                }
              }
            },
            "400": {
              "description": "Invalid user id"
            },
            "404": {
              "description": "User not found"
            }
          }
        }
      }
    },
    "definitions": {
      "Pet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string",
            "example": "Bella"
          },
          "type": {
            "type": "string",
            "example": "dog",
            "enum": ["dog", "cat", "bird", "fish", "hamster"]
          },
          "age": {
            "type": "integer",
            "example": 3
          },
          "userId": {
            "type": "integer",
            "description": "Foreign key to the owner user (nullable)",
            "example": 1
          }
        }
      },
      "PetInput": {
        "type": "object",
        "required": ["name", "type", "age"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Bella"
          },
          "type": {
            "type": "string",
            "example": "dog",
            "enum": ["dog", "cat", "bird", "fish", "hamster"]
          },
          "age": {
            "type": "integer",
            "example": 3
          },
          "userId": {
            "type": "integer",
            "description": "Optional owner user ID",
            "example": 1
          }
        }
      },
      "PetWithOwner": {
        "allOf": [
          { "$ref": "#/definitions/Pet" },
          {
            "type": "object",
            "properties": {
              "fullname": {
                "type": "string",
                "nullable": true,
                "description": "Owner full name (null if pet has no owner)",
                "example": "John Doe"
              }
            }
          }
        ]
      }
    }
  }
